{
  "name": "TypespecUIAutomation",
  "displayName": "TypespecUIAutomation",
  "version": "0.0.1",
  "description": "Typespec UI automation project based on playwright",
  "license": "MIT",
  "scripts": {
    "test": "vitest --root src",
    "test:create": "vitest --root ./src/createTypespec",
    "test:emit": "vitest --root ./src/emitTypespec",
    "test:import": "vitest --root ./src/importTypespec",
    "test:preview": "vitest --root ./src/previewTypespec"
  },
